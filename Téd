-- ==================== MAIN TAB ====================
local MainTab = Window:CreateTab("Main", 4483362458)

-- Variables
local SelectedPlayer = nil
local TargetCharacter = nil
local AutoDistanceEnabled = true
local DesiredDistance = 51
local ESPEnabled = false
local Blacklist = {}

local PlayerOptions = {}
local BlacklistOptions = {}

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer

local function UpdatePlayerLists()
    PlayerOptions = {}
    BlacklistOptions = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local text = player.DisplayName .. " (" .. player.Name .. ")"
            table.insert(PlayerOptions, text)
            table.insert(BlacklistOptions, text)
        end
    end
end
UpdatePlayerLists()

-- ==================== LOCK ON SECTION ====================
MainTab:CreateSection("🎯 Lock On")

local TargetDropdown = MainTab:CreateDropdown({
    Name = "Chọn Người Chơi Lock On",
    Options = PlayerOptions,
    CurrentOption = {},
    Callback = function(CurrentOption)
        if #CurrentOption > 0 then
            local selectedText = CurrentOption[1]
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.DisplayName .. " (" .. plr.Name .. ")" == selectedText then
                    SelectedPlayer = plr
                    Rayfield:Notify({Title = "Lock On", Content = "Đang nhắm: " .. plr.DisplayName, Duration = 3})
                    break
                end
            end
        end
    end,
})

-- ==================== ESP SECTION (RIÊNG BIỆT) ====================
MainTab:CreateSection("🔍 ESP Settings")

local ESPToggle = MainTab:CreateToggle({
    Name = "Bật / Tắt ESP",
    CurrentValue = false,
    Callback = function(Value)
        ESPEnabled = Value
        Rayfield:Notify({
            Title = "ESP",
            Content = Value and "✅ ESP đã BẬT" or "❌ ESP đã TẮT",
            Duration = 3,
        })
    end,
})

local BlacklistDropdown = MainTab:CreateDropdown({
    Name = "🚫 Blacklist ESP (Không hiển thị ESP)",
    Options = BlacklistOptions,
    CurrentOption = {},
    MultiSelection = true,
    Callback = function(CurrentOption)
        Blacklist = {}
        for _, text in ipairs(CurrentOption) do
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.DisplayName .. " (" .. plr.Name .. ")" == text then
                    table.insert(Blacklist, plr)
                    break
                end
            end
        end
        Rayfield:Notify({Title = "Blacklist Updated", Content = "Đã loại " .. #CurrentOption .. " người khỏi ESP", Duration = 2})
    end,
})

MainTab:CreateButton({
    Name = "🔄 Refresh Danh Sách",
    Callback = function()
        UpdatePlayerLists()
        TargetDropdown:Refresh(PlayerOptions)
        BlacklistDropdown:Refresh(BlacklistOptions)
