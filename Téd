local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Combat :))",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "của thịnh",
    ConfigurationSaving = { Enabled = true, FolderName = "LockOnConfig", FileName = "Settings" },
    KeySystem = false,
