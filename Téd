})

-- ==================== AUTO DISTANCE SECTION ====================
MainTab:CreateSection("📏 Auto Distance")

MainTab:CreateToggle({
    Name = "Auto Giữ Khoảng Cách",
    CurrentValue = true,
    Callback = function(Value)
        AutoDistanceEnabled = Value
    end,
})

MainTab:CreateSlider({
    Name = "Khoảng Cách (Studs)",
    Range = {30, 100},
    Increment = 1,
    CurrentValue = 51,
    Callback = function(Value)
        DesiredDistance = Value
    end,
})

-- ==================== ESP FUNCTIONS ====================
local ESPObjects = {}

local function CreateESP(plr)
    if not plr.Character or ESPObjects[plr] then return end
    if table.find(Blacklist, plr) then return end

    local char = plr.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local Billboard = Instance.new("BillboardGui")
    Billboard.Adornee = root
    Billboard.Size = UDim2.new(0, 220, 0, 70)
    Billboard.StudsOffset = Vector3.new(0, 4, 0)
    Billboard.AlwaysOnTop = true
    Billboard.Parent = root

    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.BackgroundTransparency = 0.3
    TextLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    TextLabel.TextColor3 = Color3.new(1, 1, 1)
    TextLabel.TextStrokeTransparency = 0
    TextLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    TextLabel.Font = Enum.Font.GothamBold
    TextLabel.TextSize = 7.5
    TextLabel.Parent = Billboard

    ESPObjects[plr] = Billboard

    task.spawn(function()
        while ESPEnabled and ESPObjects[plr] and plr.Character and plr.Character:FindFirstChild("Humanoid") do
            local hum = plr.Character.Humanoid
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hum and myRoot then
                local distance = math.floor((myRoot.Position - root.Position).Magnitude)
                local hpPercent = math.floor((hum.Health / hum.MaxHealth) * 100)
                
                TextLabel.Text = string.format("%s\n📍 %d studs\n❤️ %d%%", plr.DisplayName, distance, hpPercent)
                
                if hpPercent > 70 then
                    TextLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
                elseif hpPercent > 35 then
                    TextLabel.TextColor3 = Color3.fromRGB(255, 220, 0)
                else
                    TextLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
                end
            end
            task.wait(0.15)
        end
    end)
end

local function RemoveESP(plr)
    if ESPObjects[plr] then
        ESPObjects[plr]:Destroy()
        ESPObjects[plr] = nil
    end
end

-- ESP Manager
task.spawn(function()
    while true do
        if ESPEnabled then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then
                    if not table.find(Blacklist, plr) then
                        CreateESP(plr)
                    else
                        RemoveESP(plr)
                    end
                end
            end
        else
            for plr in pairs(ESPObjects) do
                RemoveESP(plr)
            end
        end
        task.wait(0.8)
    end
end)

-- ==================== MAIN LOOPS ====================
local function FireLockOn()
    if not SelectedPlayer or not SelectedPlayer.Character then return end
    TargetCharacter = SelectedPlayer.Character
    pcall(function()
        ReplicatedStorage.Packages._Index["sleitnick_knit@1.4.7"].knit.Services.SkillManager.RE.LockedOnChanged:FireServer(TargetCharacter)
    end)
end

local function AutoKeepDistance()
    if not AutoDistanceEnabled or not TargetCharacter then return end
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetRoot = TargetCharacter:FindFirstChild("HumanoidRootPart")
    if root and targetRoot then
        local dist = (root.Position - targetRoot.Position).Magnitude
        if dist < DesiredDistance then
            local dir = (root.Position - targetRoot.Position).Unit
            local newPos = targetRoot.Position + dir * DesiredDistance
            TweenService:Create(root, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {CFrame = CFrame.new(newPos, targetRoot.Position)}):Play()
        end
    end
end

task.spawn(function()
    while true do
        FireLockOn()
        AutoKeepDistance()
        task.wait(0.000001)
    end
end)

-- Auto refresh
task.spawn(function()
    while true do
        task.wait(10)
        UpdatePlayerLists()
        pcall(function()
            TargetDropdown:Refresh(PlayerOptions)
            BlacklistDropdown:Refresh(BlacklistOptions)
        end)
    end
end)

